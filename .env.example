GEMINI_API_KEY=your_gemini_api_key_here

# Runtime mode profile: accurate, balanced, or fast
ASSISTANT_MODE=balanced

# Optional overrides (if omitted, mode defaults are used)
RETRIEVAL_TOP_K=6
GEMINI_TEMPERATURE=0.2

# Advanced optional speed/quality toggles
# ENABLE_RERANK=true
# ENABLE_RETRY=true
# RETRIEVAL_OVERFETCH_MULTIPLIER=2
# CONTEXT_SNIPPET_LIMIT=900